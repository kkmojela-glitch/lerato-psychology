/* ==========================================================================
   2. UPGRADED HEADER & NAVIGATION
   ========================================================================== */
.main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
    border-bottom: 1px solid rgba(44, 74, 62, 0.05);
    z-index: 1000;
    transition: var(--transition-smooth);
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 22px 24px;
    transition: var(--transition-smooth);
}

/* Luxury branding adjustments */
.logo-text {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--primary-color);
    line-height: 1.1;
}

.logo-sub {
    font-family: var(--font-sans);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--primary-light);
    font-weight: 500;
    margin-top: 2px;
}

.nav-menu {
    display: flex;
    align-items: center;
    gap: 40px;
}

.nav-link {
    text-decoration: none;
    color: var(--text-dark);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.5px;
    transition: var(--transition-smooth);
    opacity: 0.8;
}

.nav-link:hover, .nav-link.active {
    color: var(--primary-color);
    opacity: 1;
}

/* Subtle underline effect for active/hover states */
.nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: -6px;
    left: 0;
    background-color: var(--accent-color);
    transition: var(--transition-smooth);
}

.nav-link:hover::after, .nav-link.active::after {
    width: 100%;
}

.btn-nav {
    background-color: var(--primary-color);
    color: var(--bg-white) !important;
    padding: 12px 24px;
    border-radius: 50px; /* Elegant pill shape */
    box-shadow: 0 4px 15px rgba(44, 74, 62, 0.15);
}

.btn-nav:hover {
    background-color: var(--primary-light);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(44, 74, 62, 0.2);
}

.btn-nav::after {
    display: none; /* Remove underline from button */
}

/* ==========================================================================
   3. UPGRADED HERO SECTION
   ========================================================================== */
.hero-section {
    background: linear-gradient(180deg, #f4f6f5 0%, var(--bg-white) 100%);
    padding: 180px 0 120px 0;
    min-height: 95vh;
    display: flex;
    align-items: center;
}

.hero-container {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 80px;
    align-items: center;
}

.hero-tagline {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--primary-light);
    font-weight: 700;
    display: inline-block;
    margin-bottom: 20px;
    background-color: rgba(44, 74, 62, 0.06);
    padding: 6px 16px;
    border-radius: 50px;
}

.hero-content h1 {
    font-family: var(--font-serif);
    font-size: 56px;
    font-weight: 400;
    color: var(--primary-color);
    line-height: 1.15;
    margin-bottom: 28px;
}

.hero-content p {
    font-size: 18px;
    color: var(--text-muted);
    margin-bottom: 44px;
    max-width: 560px;
    line-height: 1.7;
}

.hero-cta-group {
    display: flex;
    align-items: center;
    gap: 24px;
}

.hero-cta-group .btn-primary {
    border-radius: 50px;
    padding: 16px 32px;
    box-shadow: 0 10px 25px rgba(44, 74, 62, 0.15);
}

.hero-cta-group .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(44, 74, 62, 0.25);
}

.hero-cta-group .btn-secondary {
    border-radius: 50px;
    padding: 16px 32px;
    border: 1px solid rgba(44, 74, 62, 0.2);
}

.hero-cta-group .btn-secondary:hover {
    border-color: var(--primary-color);
    background-color: transparent;
    transform: translateY(-2px);
}

/* Premium Image Presentation */
.hero-image-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
}

.hero-blob-bg {
    position: absolute;
    width: 110%;
    height: 110%;
    background: radial-gradient(circle, rgba(226,237,232,1) 0%, rgba(244,246,245,0.5) 100%);
    border-radius: 65% 35% 55% 45% / 45% 55% 35% 65%;
    z-index: 1;
    top: -5%;
    animation: blob-bounce 12s ease-in-out infinite;
}

.hero-img {
    position: relative;
    width: 100%;
    max-width: 400px;
    height: auto;
    z-index: 2;
    border-radius: 24px; /* Soft luxurious rounded corners */
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
}
